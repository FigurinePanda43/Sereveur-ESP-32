# Domaine racine (sans https://)
DOMAIN=mondomaine.com

# Cloudflare API
# Créer un token sur https://dash.cloudflare.com/profile/api-tokens
# Permissions requises : Zone > DNS > Edit
CLOUDFLARE_API_TOKEN=

# Zone ID du domaine (onglet "Overview" du domaine sur Cloudflare)
CLOUDFLARE_ZONE_ID=

# ID du tunnel Cloudflare (créé dans Zero Trust > Tunnels)
CLOUDFLARE_TUNNEL_ID=

# Token du tunnel (affiché lors de la création du tunnel)
CLOUDFLARE_TUNNEL_TOKEN=

# Clé secrète de l'application (générer avec : openssl rand -hex 32)
SECRET_KEY=changeme
