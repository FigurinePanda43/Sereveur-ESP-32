# Domaine racine (sans https://, sans slash final)
DOMAIN=mondomaine.com

# Cloudflare API
# Créer un token sur https://dash.cloudflare.com/profile/api-tokens
# Permissions requises : Zone > DNS > Edit, Zone > Zone > Read
CLOUDFLARE_API_TOKEN=

# Zone ID du domaine (onglet "Overview" du domaine sur Cloudflare, colonne droite)
CLOUDFLARE_ZONE_ID=

# ID du tunnel Cloudflare (créé dans Zero Trust > Networks > Tunnels)
CLOUDFLARE_TUNNEL_ID=

# Token du tunnel (affiché lors de la création du tunnel, commence par eyJ...)
CLOUDFLARE_TUNNEL_TOKEN=

# Clé secrète de l'application (générer avec : openssl rand -hex 32)
# Générée automatiquement par scripts/install.sh
APP_SECRET_KEY=changeme

# Chemin vers la base de données SQLite
# Ne pas modifier sauf si vous changez le volume dans docker-compose.yml
DATABASE_URL=sqlite:////data/devices.db
